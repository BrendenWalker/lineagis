{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lineagis.dev/schemas/inspect-report.v1.json",
  "title": "lineagis inspect report",
  "description": "Machine-readable trust report from `lineagis inspect --output json` (FR-DX-006, AC-DX-005).",
  "type": "object",
  "required": ["version", "namespace", "artifact", "digest", "overall", "checks"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Report schema version."
    },
    "namespace": { "type": "string" },
    "artifact": { "type": "string" },
    "digest": { "type": "string" },
    "overall": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["priority", "status", "message"],
        "additionalProperties": false,
        "properties": {
          "priority": { "type": "string", "enum": ["must", "should"] },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "message": { "type": "string" },
          "requirement_id": { "type": "string" },
          "rule_id": { "type": "string" }
        }
      }
    }
  }
}
