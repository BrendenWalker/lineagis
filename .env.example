# PostgreSQL
POSTGRES_USER=verity
POSTGRES_PASSWORD=verity
POSTGRES_DB=verity

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_REGISTRY_BUCKET=registry

# Verity API
VERITY_API_ADDR=:8080
VERITY_API_PORT=8080
VERITY_DATABASE_URL=postgres://verity:verity@localhost:5432/verity?sslmode=disable
# Zot OCI registry (local compose); supports OCI Artifact manifests (ADR-0001)
VERITY_REGISTRY_URL=http://localhost:5000
VERITY_LOG_LEVEL=info
VERITY_LOG_FORMAT=text
VERITY_MIGRATE_ON_STARTUP=true
# Local dev bearer for API write routes (OQ-API-002; use alongside OIDC in CI)
VERITY_DEV_TOKEN=dev-local-token
# GitHub Actions OIDC (optional locally; set in CI for real JWT auth)
# VERITY_OIDC_ISSUER=https://token.actions.githubusercontent.com
# VERITY_OIDC_AUDIENCE=verity-api

# Verity CLI (verity publish)
VERITY_API_URL=http://localhost:8080
VERITY_TOKEN=dev-local-token
# Local publish without Sigstore (no Fulcio/Rekor): verity publish --skip-sign or:
# VERITY_SKIP_SIGN=1
# Keyless signing (CI): SIGSTORE_ID_TOKEN with aud containing "sigstore", or GitHub Actions
# ambient OIDC (ACTIONS_ID_TOKEN_REQUEST_URL / ACTIONS_ID_TOKEN_REQUEST_TOKEN, id-token: write).
# Optional Sigstore endpoints (defaults: public Fulcio + Rekor):
# SIGSTORE_FULCIO_URL=https://fulcio.sigstore.dev
# SIGSTORE_REKOR_URL=https://rekor.sigstore.dev
# SIGSTORE_ID_TOKEN=

# Optional TLS (production)
# VERITY_API_TLS_CERT=/path/to/cert.pem
# VERITY_API_TLS_KEY=/path/to/key.pem
