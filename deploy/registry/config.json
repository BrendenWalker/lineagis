{
  "distSpecVersion": "1.1.0",
  "storage": {
    "rootDirectory": "/tmp/zot",
    "dedupe": false,
    "storageDriver": {
      "name": "s3",
      "rootdirectory": "/registry",
      "region": "us-east-1",
      "regionendpoint": "http://minio:9000",
      "bucket": "registry",
      "accesskey": "minioadmin",
      "secretkey": "minioadmin",
      "forcepathstyle": true,
      "secure": false,
      "skipverify": true
    }
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5000",
    "compat": ["docker2s2"]
  },
  "log": {
    "level": "info"
  }
}
