# PostgreSQL
POSTGRES_USER=lineagis
POSTGRES_PASSWORD=lineagis
POSTGRES_DB=lineagis

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_REGISTRY_BUCKET=registry

# Lineagis API
LINEAGIS_API_ADDR=:8080
LINEAGIS_API_PORT=8080
LINEAGIS_DATABASE_URL=postgres://lineagis:lineagis@localhost:5432/lineagis?sslmode=disable
# Zot OCI registry (local compose); supports OCI Artifact manifests (ADR-0001)
LINEAGIS_REGISTRY_URL=http://localhost:5000
LINEAGIS_LOG_LEVEL=info
LINEAGIS_LOG_FORMAT=text
LINEAGIS_MIGRATE_ON_STARTUP=true
# Local dev bearer for API write routes (OQ-API-002; use alongside OIDC in CI)
LINEAGIS_DEV_TOKEN=dev-local-token
# GitHub Actions OIDC (optional locally; set in CI for real JWT auth)
# LINEAGIS_OIDC_ISSUER=https://token.actions.githubusercontent.com
# LINEAGIS_OIDC_AUDIENCE=lineagis-api
# Optional: GitHub PAT for repository-ownership API verification (FR-POL-013)
# LINEAGIS_GITHUB_TOKEN=

# Lineagis CLI (lineagis publish)
LINEAGIS_API_URL=http://localhost:8080
LINEAGIS_TOKEN=dev-local-token
# Local publish without Sigstore (no Fulcio/Rekor): lineagis publish --skip-sign or:
# LINEAGIS_SKIP_SIGN=1
# Keyless signing (CI): LINEAGIS_SIGSTORE_ID_TOKEN or SIGSTORE_ID_TOKEN (aud must include sigstore),
# or GitHub Actions ambient OIDC (ACTIONS_ID_TOKEN_REQUEST_URL / ACTIONS_ID_TOKEN_REQUEST_TOKEN).
# Sigstore endpoints — default public-good; LINEAGIS_* overrides SIGSTORE_*:
# LINEAGIS_SIGSTORE_FULCIO_URL=https://fulcio.sigstore.dev
# LINEAGIS_SIGSTORE_REKOR_URL=https://rekor.sigstore.dev
# LINEAGIS_SIGSTORE_ID_TOKEN=
# Optional trust material for verify (self-hosted / air-gap); see docs/signing-local.md:
# LINEAGIS_SIGSTORE_TRUSTED_ROOT=/path/to/trustedroot.json
# LINEAGIS_SIGSTORE_CA_ROOTS=/path/to/ca-roots.pem
# LINEAGIS_SIGSTORE_CA_INTERMEDIATES=/path/to/ca-intermediates.pem
# LINEAGIS_SIGSTORE_ROOT_FILE=/path/to/fulcio-root.pem
# LINEAGIS_SIGSTORE_REKOR_PUBLIC_KEY=/path/to/rekor.pub
# LINEAGIS_SIGSTORE_CT_LOG_PUBLIC_KEY_FILE=/path/to/ctfe.pub
# Dev only: permissive Fulcio identity matchers for keyless verify (never in production)
# LINEAGIS_PERMISSIVE_KEYLESS_IDENTITY=1

# Optional TLS (production)
# LINEAGIS_API_TLS_CERT=/path/to/cert.pem
# LINEAGIS_API_TLS_KEY=/path/to/key.pem
